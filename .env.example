# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="GenAI Backend"
APP_ENV=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mydb
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── LLM ───────────────────────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=bedrock   # bedrock | openai | anthropic | auto
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# AWS Bedrock — uses boto3 credential chain; set these or use IAM role / ~/.aws
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
BEDROCK_API_KEY=your-bedrock-api-key
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL_ID=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_ID=claude-3-5-haiku-20241022

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_STORE_URL=
VECTOR_STORE_COLLECTION=default
